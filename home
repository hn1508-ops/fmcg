<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#2563eb">
  <meta name="description" content="PWA tra cứu sản phẩm - Dự phòng AppSheet">
  <title>📦 Tra Cứu Hàng Hóa</title>
  <link rel="manifest" href="manifest.json">
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 192 192'><rect fill='%232563eb' width='192' height='192'/><text x='96' y='140' font-size='120' fill='white' text-anchor='middle'>📦</text></svg>">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
      min-height: 100vh;
      padding: 16px;
      color: #1f2937;
    }
    
    .container {
      max-width: 600px;
      margin: 0 auto;
    }
    
    header {
      background: white;
      border-radius: 16px;
      padding: 20px;
      margin-bottom: 16px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
      text-align: center;
    }
    
    header h1 {
      font-size: 24px;
      margin-bottom: 8px;
    }
    
    .status {
      font-size: 12px;
      color: #6b7280;
    }
    
    .status.online::before {
      content: "🟢 ";
    }
    
    .status.offline::before {
      content: "🔴 ";
    }
    
    .input-group {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
    }
    
    input[type="text"] {
      flex: 1;
      padding: 12px 16px;
      border: 2px solid #e5e7eb;
      border-radius: 12px;
      font-size: 16px;
      background: white;
      transition: all 0.3s ease;
    }
    
    input[type="text"]:focus {
      outline: none;
      border-color: #2563eb;
      box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
    }
    
    button {
      padding: 12px 20px;
      border: none;
      border-radius: 12px;
      font-size: 16px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.3s ease;
      background: white;
    }
    
    .btn-primary {
      background: #2563eb;
      color: white;
    }
    
    .btn-primary:hover {
      background: #1d4ed8;
      transform: translateY(-2px);
      box-shadow: 0 4px 12px rgba(37, 99, 235, 0.4);
    }
    
    .btn-primary:active {
      transform: translateY(0);
    }
    
    .btn-secondary {
      background: #10b981;
      color: white;
    }
    
    .btn-secondary:hover {
      background: #059669;
    }
    
    .btn-danger {
      background: #ef4444;
      color: white;
      padding: 8px 12px;
      font-size: 12px;
    }
    
    .tabs {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
      background: white;
      padding: 8px;
      border-radius: 12px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    
    .tab-btn {
      flex: 1;
padding: 10px;
      border: none;
      border-radius: 8px;
      background: #f3f4f6;
      cursor: pointer;
      font-weight: 600;
      transition: all 0.3s ease;
    }
    
    .tab-btn.active {
      background: #2563eb;
      color: white;
    }
    
    .results {
      background: white;
      border-radius: 12px;
      padding: 16px;
      box-shadow: 0 4px 6px rgba(0,0,0,0.1);
    }
    
    .result-item {
      padding: 12px;
      border-left: 4px solid #2563eb;
      margin-bottom: 8px;
      background: #f9fafb;
      border-radius: 8px;
      transition: all 0.3s ease;
    }
    
    .result-item:hover {
      background: #f3f4f6;
      transform: translateX(4px);
    }
    
    .product-name {
      font-weight: 700;
      font-size: 16px;
      margin-bottom: 4px;
      color: #1f2937;
    }
    
    .product-code {
      font-size: 12px;
      color: #6b7280;
      margin-bottom: 8px;
      font-family: 'Courier New', monospace;
    }
    
    .product-details {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 8px;
      font-size: 14px;
    }
    
    .detail {
      display: flex;
      justify-content: space-between;
    }
    
    .detail-label {
      color: #6b7280;
      font-weight: 600;
    }
    
    .detail-value {
      color: #1f2937;
      font-weight: 700;
    }
    
    .price {
      color: #059669;
    }
    
    .empty-state {
      text-align: center;
      padding: 40px 20px;
      color: #6b7280;
    }
    
    .loading {
      text-align: center;
      padding: 20px;
    }
    
    .spinner {
      border: 3px solid #e5e7eb;
      border-top: 3px solid #2563eb;
      border-radius: 50%;
      width: 32px;
      height: 32px;
      animation: spin 0.8s linear infinite;
      margin: 0 auto 12px;
    }
    
    @keyframes spin {
      0% { transform: rotate(0deg); }
      100% { transform: rotate(360deg); }
    }
    
    .error {
      background: #fee2e2;
      color: #991b1b;
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 16px;
      border-left: 4px solid #dc2626;
    }
    
    .success {
      background: #dcfce7;
      color: #166534;
      padding: 12px;
      border-radius: 8px;
      margin-bottom: 16px;
      border-left: 4px solid #16a34a;
    }
    
    .controls {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
    }
  </style>
</head>
<body>
  <div class="container">
    <!-- Header -->
    <header>
      <h1>📦 Tra Cứu Hàng Hóa</h1>
      <div id="status" class="status offline">Offline</div>
    </header>
    
    <!-- Tabs -->
    <div class="tabs">
      <button class="tab-btn active" onclick="switchTab('search')">🔍 Tra Cứu</button>
      <button class="tab-btn" onclick="switchTab('scan')">📱 Scan</button>
      <button class="tab-btn" onclick="switchTab('settings')">⚙️ Cài Đặt</button>
    </div>
    
    <!-- Tab: Tra Cứu -->
    <div id="search-tab" class="tab-content">
<div style="margin-bottom: 16px;">
        <div class="input-group">
          <input 
            type="text" 
            id="searchInput" 
            placeholder="Nhập barcode hoặc tên sản phẩm..."
            onkeypress="handleEnter(event)"
          >
          <button class="btn-primary" onclick="search()">🔍</button>
        </div>
        <button class="btn-secondary" style="width: 100%;" onclick="loadAll()">Tải Tất Cả</button>
      </div>
      <div id="results" class="results">
        <div class="empty-state">👇 Nhập để tìm kiếm</div>
      </div>
    </div>
    
    <!-- Tab: Scan -->
    <div id="scan-tab" class="tab-content" style="display: none;">
      <div style="margin-bottom: 16px;">
        <button class="btn-primary" style="width: 100%;" onclick="startCamera()">🎥 Mở Camera</button>
      </div>
      <div id="camera-container" style="display: none; margin-bottom: 16px;">
        <video id="video" style="width: 100%; border-radius: 12px; margin-bottom: 8px;"></video>
        <button class="btn-danger" style="width: 100%;" onclick="stopCamera()">❌ Đóng Camera</button>
      </div>
      <div id="scan-results" class="results">
        <div class="empty-state">Quét barcode để bắt đầu</div>
      </div>
    </div>
    
    <!-- Tab: Settings -->
    <div id="settings-tab" class="tab-content" style="display: none;">
      <div class="results">
        <h3 style="margin-bottom: 16px;">Cấu Hình</h3>
        <div style="margin-bottom: 16px;">
          <label style="display: block; margin-bottom: 8px; font-weight: 600;">
            Apps Script URL:
          </label>
          <input 
            type="text" 
            id="apiUrl" 
            placeholder="https://script.google.com/macros/d/..."
            style="width: 100%;"
          >
        </div>
        <button class="btn-primary" style="width: 100%;" onclick="saveSettings()">💾 Lưu</button>
        
        <h3 style="margin-top: 24px; margin-bottom: 16px;">Dữ Liệu</h3>
        <button class="btn-secondary" style="width: 100%; margin-bottom: 8px;" onclick="syncData()">
          🔄 Đồng Bộ Dữ Liệu
        </button>
        <button class="btn-danger" style="width: 100%;" onclick="clearCache()">🗑️ Xóa Cache</button>
        
        <div id="sync-status" style="margin-top: 16px; font-size: 12px; color: #6b7280;"></div>
      </div>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/jsbarcode@3.11.5/dist/JsBarcode.all.min.js"></script>
  <script src="https://cdn.jsdelivr.net/npm/@zxing/library@0.20.0/umd/index.min.js"></script>
  <script src="app.js"></script>
  <script>
    // Register service worker
    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('sw.js').catch(err => 
        console.log('SW registration failed:', err)
      );
    }
    
    // Check online status
    window.addEventListener('online', () => updateStatus(true));
window.addEventListener('offline', () => updateStatus(false));
    updateStatus(navigator.onLine);
  </script>
</body>
</html>
